<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 交易系统主进程：崩溃自动重启 -->
    <key>Label</key>
    <string>com.trading</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/xiaofeng/trading-system/venv/bin/python</string>
        <string>/Users/xiaofeng/trading-system/main.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/xiaofeng/trading-system</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/xiaofeng/trading-system/logs/trading.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/xiaofeng/trading-system/logs/trading.log</string>

    <key>ThrottleInterval</key>
    <integer>15</integer>
</dict>
</plist>
