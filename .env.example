# ── Exchange API Keys ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# .env is listed in .gitignore and NEVER committed.

BINANCE_API_KEY=
BINANCE_SECRET=
BINANCE_SPOT_API_KEY=
BINANCE_SPOT_SECRET=

OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=
OKX_SPOT_API_KEY=
OKX_SPOT_SECRET=
OKX_SPOT_PASSPHRASE=

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Trading System API Auth ───────────────────────────────────────────────────
# Generate a strong random key, e.g.: openssl rand -hex 32
TRADING_API_KEY=

# ── Server Binding ────────────────────────────────────────────────────────────
# Behind nginx reverse proxy, bind to localhost only
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8080

# ── CORS ─────────────────────────────────────────────────────────────────────
# Production: set to your actual domain
# CORS_ORIGINS=https://yourdomain.com

# ── Chain / DEX (optional) ────────────────────────────────────────────────────
# ETHEREUM_RPC_URL=
# ETHEREUM_PRIVATE_KEY=
# ARBITRUM_RPC_URL=
# ARBITRUM_PRIVATE_KEY=
